IXI_O_AGENT_STORAGE_DIR=./private-voice-inbox
IXI_O_AGENT_INGEST_SECRET=replace-with-local-random-secret
IXI_O_AGENT_MISO_GATEWAY_PORT=3321
IXI_O_AGENT_MISO_UPSTREAM_URL=http://localhost:3000
IXI_O_AGENT_MISO_GATEWAY_TOKEN=replace-with-short-lived-demo-token
N8N_ENCRYPTION_KEY=replace-with-local-random-secret
IXI_O_AGENT_INGEST_URL=http://localhost:3000/api/ingest/channel-talk
IXI_O_AGENT_OPENAPI_INGEST_URL=http://localhost:3000/api/ingest/channel-talk/openapi
IXI_O_AGENT_BACKFILL_URL=http://localhost:3000/api/backfill/channel-talk
N8N_OWNER_EMAIL=ixi-o-agent.local@example.com
N8N_OWNER_PASSWORD=replace-with-local-random-password

# Store these only in your local environment or n8n credentials.
CHANNEL_TALK_ACCESS_KEY=
CHANNEL_TALK_ACCESS_SECRET=
CHANNEL_TALK_CHANNEL_ID=
CHANNEL_TALK_WEBHOOK_URL=https://<trycloudflare-host>/webhook/channel-talk-ixi-o-agent
CHANNEL_TALK_WEBHOOK_NAME=ixi-O Agent n8n realtime
CHANNEL_TALK_WEBHOOK_SCOPES=userChat.opened,message.created.userChat
CHANNEL_TALK_BACKFILL_STATE=closed
CHANNEL_TALK_BACKFILL_STATES=closed
CHANNEL_TALK_BACKFILL_LIMIT=20
CHANNEL_TALK_BACKFILL_PAGES=1
CHANNEL_TALK_MESSAGE_LIMIT=100

# Kiya/Hermes outbound notification.
# Automatic notification is ON by default after EXAONE processing.
# Set IXI_O_AGENT_KIYA_AUTO_NOTIFY=false to disable it.
IXI_O_AGENT_KIYA_AUTO_NOTIFY=true
HERMES_AGENT_WEBHOOK_URL=
HERMES_AGENT_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_KIYA_CHAT_ID=

# Optional local model overrides. Defaults point to ./models when unset.
IXI_O_AGENT_WHISPER_MODEL_PATH=
IXI_O_AGENT_WHISPER_CLI=
IXI_O_AGENT_EXAONE_MODEL_PATH=
IXI_O_AGENT_LLAMA_CLI=
IXI_O_AGENT_EXAONE_TIMEOUT_MS=120000

# Optional hosted inference fallback. Local-first demo does not need this.
FRIENDLI_TOKEN=
