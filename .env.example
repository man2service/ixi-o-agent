PHONE_CLAW_STORAGE_DIR=./private-voice-inbox
PHONE_CLAW_INGEST_SECRET=replace-with-local-random-secret
N8N_ENCRYPTION_KEY=replace-with-local-random-secret
PHONE_CLAW_INGEST_URL=http://localhost:3000/api/ingest/channel-talk
PHONE_CLAW_OPENAPI_INGEST_URL=http://localhost:3000/api/ingest/channel-talk/openapi
PHONE_CLAW_BACKFILL_URL=http://localhost:3000/api/backfill/channel-talk
N8N_OWNER_EMAIL=phoneclaw.local@example.com
N8N_OWNER_PASSWORD=replace-with-local-random-password

# Store these only in your local environment or n8n credentials.
CHANNEL_TALK_ACCESS_KEY=
CHANNEL_TALK_ACCESS_SECRET=
CHANNEL_TALK_CHANNEL_ID=
CHANNEL_TALK_WEBHOOK_URL=https://<trycloudflare-host>/webhook/channel-talk-phone-claw
CHANNEL_TALK_WEBHOOK_NAME=Phone-Claw n8n realtime
CHANNEL_TALK_WEBHOOK_SCOPES=userChat.opened,message.created.userChat
CHANNEL_TALK_BACKFILL_STATE=closed
CHANNEL_TALK_BACKFILL_STATES=closed
CHANNEL_TALK_BACKFILL_LIMIT=20
CHANNEL_TALK_BACKFILL_PAGES=1
CHANNEL_TALK_MESSAGE_LIMIT=100
