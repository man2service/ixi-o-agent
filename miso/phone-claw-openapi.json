{
  "openapi": "3.1.0",
  "info": {
    "title": "Phone-Claw Restricted Voice Session Tool",
    "version": "0.1.0",
    "description": "Restricted local API for MISO to list reviewed Phone-Claw voice sessions and read only user-approved redacted handoff payloads. Raw audio and raw transcript text are never returned."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Phone-Claw app. Replace with a Cloudflare Tunnel URL for MISO cloud access."
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/miso/voice-sessions": {
      "get": {
        "operationId": "listVoiceSessions",
        "summary": "List restricted voice-session metadata",
        "description": "Lists local Phone-Claw voice sessions without raw transcript or raw audio. Use this before reading a session detail.",
        "responses": {
          "200": {
            "description": "Voice-session metadata list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListVoiceSessionsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/miso/voice-sessions/{sessionId}": {
      "get": {
        "operationId": "readVoiceSessionHandoff",
        "summary": "Read a reviewed redacted voice-session handoff",
        "description": "Returns a redacted MISO handoff payload only after local human review allows external workflow access. Otherwise returns a blocked reason.",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "description": "Phone-Claw local voice session ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Restricted voice-session detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadVoiceSessionResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "description": "Session not found"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Use PHONE_CLAW_INGEST_SECRET as the bearer token."
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid Phone-Claw local token"
      }
    },
    "schemas": {
      "ListVoiceSessionsResponse": {
        "type": "object",
        "required": ["ok", "sessions"],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "sessions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VoiceSessionSummary"
            }
          }
        }
      },
      "ReadVoiceSessionResponse": {
        "type": "object",
        "required": ["ok", "session"],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "session": {
            "$ref": "#/components/schemas/VoiceSessionDetail"
          }
        }
      },
      "VoiceSessionSummary": {
        "type": "object",
        "required": [
          "sessionId",
          "status",
          "source",
          "mode",
          "sourceStartedAt",
          "createdAt",
          "utteranceCount",
          "review",
          "safety"
        ],
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "sourceStartedAt": {
            "type": "string"
          },
          "sourceEndedAt": {
            "type": ["string", "null"]
          },
          "createdAt": {
            "type": "string"
          },
          "utteranceCount": {
            "type": "integer"
          },
          "review": {
            "$ref": "#/components/schemas/ReviewState"
          },
          "safety": {
            "$ref": "#/components/schemas/SafetyState"
          }
        }
      },
      "VoiceSessionDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/VoiceSessionSummary"
          },
          {
            "type": "object",
            "required": ["handoff"],
            "properties": {
              "handoff": {
                "$ref": "#/components/schemas/HandoffState"
              }
            }
          }
        ]
      },
      "ReviewState": {
        "type": "object",
        "required": ["reviewed", "externalAllowed"],
        "properties": {
          "reviewed": {
            "type": "boolean"
          },
          "externalAllowed": {
            "type": "boolean"
          }
        }
      },
      "SafetyState": {
        "type": "object",
        "required": [
          "redactionApplied",
          "rawTranscriptIncluded",
          "rawAudioIncluded",
          "humanReviewRequired"
        ],
        "properties": {
          "redactionApplied": {
            "const": true
          },
          "rawTranscriptIncluded": {
            "const": false
          },
          "rawAudioIncluded": {
            "const": false
          },
          "humanReviewRequired": {
            "const": true
          }
        }
      },
      "HandoffState": {
        "type": "object",
        "required": ["availableForExternalWorkflow"],
        "properties": {
          "availableForExternalWorkflow": {
            "type": "boolean"
          },
          "blockedReason": {
            "type": "string"
          },
          "redactedPayload": {
            "$ref": "#/components/schemas/MisoHandoffPayload"
          }
        }
      },
      "MisoHandoffPayload": {
        "type": "object",
        "required": [
          "schemaVersion",
          "eventType",
          "source",
          "sourceSystem",
          "sourceMode",
          "sessionId",
          "startedAt",
          "endedAt",
          "summary",
          "urgency",
          "requiredTeams",
          "actionItems",
          "redactionApplied",
          "humanReviewRequired",
          "rawTranscriptIncluded",
          "rawAudioIncluded",
          "reviewStatus",
          "sourceRefs"
        ],
        "properties": {
          "schemaVersion": {
            "const": "phone-claw.miso.voice-session.v0"
          },
          "eventType": {
            "const": "voice-session.created"
          },
          "source": {
            "const": "phone-claw-private-local-voice-bridge"
          },
          "sourceSystem": {
            "const": "channel_talk"
          },
          "sourceMode": {
            "type": "string"
          },
          "sessionId": {
            "type": "string"
          },
          "startedAt": {
            "type": "string"
          },
          "endedAt": {
            "type": ["string", "null"]
          },
          "summary": {
            "type": "string"
          },
          "urgency": {
            "type": "string",
            "enum": ["unknown", "low", "normal", "high", "critical"]
          },
          "requiredTeams": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "actionItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HandoffActionItem"
            }
          },
          "redactionApplied": {
            "const": true
          },
          "humanReviewRequired": {
            "const": true
          },
          "rawTranscriptIncluded": {
            "const": false
          },
          "rawAudioIncluded": {
            "const": false
          },
          "reviewStatus": {
            "type": "string",
            "enum": ["pending_human_review", "approved_for_external_workflow"]
          },
          "sourceRefs": {
            "$ref": "#/components/schemas/SourceRefs"
          }
        }
      },
      "HandoffActionItem": {
        "type": "object",
        "required": ["text", "owner", "status"],
        "properties": {
          "text": {
            "type": "string"
          },
          "owner": {
            "type": ["string", "null"]
          },
          "status": {
            "type": "string",
            "enum": ["open", "done", "blocked"]
          }
        }
      },
      "SourceRefs": {
        "type": "object",
        "required": ["channelId", "userChatId", "callLogId", "meetMessageId"],
        "properties": {
          "channelId": {
            "type": "string"
          },
          "userChatId": {
            "type": "string"
          },
          "callLogId": {
            "type": ["string", "null"]
          },
          "meetMessageId": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
