{
  "name": "ixi-O Agent Channel Talk Polling Backup",
  "active": false,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "minutes", "minutesInterval": 2 }]
        }
      },
      "id": "schedule",
      "name": "Every 2 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "{\n  \"states\": [\"opened\", \"snoozed\"],\n  \"chatLimit\": 10,\n  \"chatPages\": 1,\n  \"messageLimit\": 100\n}"
      },
      "id": "polling-settings",
      "name": "Polling Settings",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [500, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.IXI_O_AGENT_BACKFILL_URL || $env.PHONE_CLAW_BACKFILL_URL || 'http://host.docker.internal:3000/api/backfill/channel-talk'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "content-type",
              "value": "application/json"
            },
            {
              "name": "x-ixi-o-agent-ingest-secret",
              "value": "={{$env.IXI_O_AGENT_INGEST_SECRET || $env.PHONE_CLAW_INGEST_SECRET}}"
            }
          ]
        },
        "sendBody": true,
        "bodyContentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{$json}}"
      },
      "id": "post-backfill",
      "name": "Run ixi-O Agent Backfill",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [780, 300]
    }
  ],
  "connections": {
    "Every 2 Minutes": {
      "main": [[{ "node": "Polling Settings", "type": "main", "index": 0 }]]
    },
    "Polling Settings": {
      "main": [[{ "node": "Run ixi-O Agent Backfill", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
